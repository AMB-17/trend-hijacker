# Environment variables for TREND HIJACKER

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trend_hijacker

# Redis
REDIS_URL=redis://localhost:6379

# API Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Scraper Config
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_HOURS=1
SCRAPER_BATCH_SIZE=100

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3000

# Scheduled batch triggers
# ⚠️  SECURITY: Generate a secure random secret before deploying to production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
CRON_SECRET=CHANGEME_GENERATE_WITH_COMMAND_ABOVE

# Optional: Third-party APIs (for premium sources)
# TWITTER_BEARER_TOKEN=
# PRODUCTHUNT_API_KEY=

# Optional: Monitoring
# SENTRY_DSN=
# DATADOG_API_KEY=


# Authentication
# ⚠️  SECURITY: Generate a secure random secret before deploying to production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGEME_GENERATE_WITH_COMMAND_ABOVE

# Workers Configuration
SCRAPER_CONCURRENCY=5
TREND_ENGINE_CONCURRENCY=3

# External APIs (Optional)
# OPENAI_API_KEY=sk-...  # For AI-powered idea generation

# Feature Flags
ENABLE_PREMIUM_FEATURES=true

