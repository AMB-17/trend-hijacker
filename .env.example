# Environment variables for TREND HIJACKER

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trend_hijacker

# Redis
REDIS_URL=redis://localhost:6379

# API Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Scraper Config
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_HOURS=1
SCRAPER_BATCH_SIZE=100

# Logging
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3000

# Scheduled batch triggers
CRON_SECRET=local-dev-cron-secret

# Optional: Third-party APIs (for premium sources)
# TWITTER_BEARER_TOKEN=
# PRODUCTHUNT_API_KEY=

# Optional: Monitoring
# SENTRY_DSN=
# DATADOG_API_KEY=


# Authentication
JWT_SECRET=local-dev-jwt-secret

# Workers Configuration
SCRAPER_CONCURRENCY=5
TREND_ENGINE_CONCURRENCY=3

# External APIs (Optional)
# OPENAI_API_KEY=sk-...  # For AI-powered idea generation

# Feature Flags
ENABLE_PREMIUM_FEATURES=true

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
